{
  "name": "agentworld",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "bin": {
    "agentworld": "scripts/agentworld-cli.mjs"
  },
  "scripts": {
    "agentworld": "node scripts/agentworld-cli.mjs",
    "dev": "node scripts/agentworld-next.mjs dev",
    "build": "NODE_OPTIONS=--no-warnings=ExperimentalWarning next build",
    "start": "node scripts/agentworld-next.mjs start",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:coverage": "node --import tsx --test --experimental-test-coverage \"src/**/*.test.ts\"",
    "lint": "eslint .",
    "i18n:audit": "node scripts/i18n-audit.mjs && tsx scripts/i18n-en-audit.ts",
    "config-data:audit": "node scripts/config-data-audit.mjs",
    "quality:audit": "node scripts/repo-quality-audit.mjs",
    "security:audit": "node scripts/security-baseline-audit.mjs",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "bootstrap": "tsx scripts/setup.ts",
    "knowledge:prepare": "node scripts/knowledge-engine-smoke.mjs --prepare-only",
    "knowledge:doctor": "node scripts/knowledge-engine-smoke.mjs --doctor",
    "knowledge:smoke": "node scripts/knowledge-engine-smoke.mjs",
    "package:linux": "node scripts/package-linux.mjs"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.74.0",
    "@earendil-works/pi-ai": "0.74.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^0.551.0",
    "mermaid": "^11.15.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
