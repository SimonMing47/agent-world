    "openviking:init": "node scripts/openviking-init.mjs",
    "openviking:doctor": "node scripts/openviking-doctor.mjs",
    "openviking:cli-config": "node scripts/openviking-cli-config.mjs",
    "openviking:start": "node scripts/openviking-start.mjs",
    "openviking:smoke": "node scripts/openviking-smoke.mjs",
