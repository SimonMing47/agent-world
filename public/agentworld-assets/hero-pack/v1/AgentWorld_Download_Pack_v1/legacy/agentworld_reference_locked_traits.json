    ],
    "source_offset": [
      7,
      12
    ],
    "anchor": "top_left",
    "scale_policy": "nearest_neighbor_only"
  },
  "reference_lock": {
    "description_zh": "该版本直接从用户参考图做透明化、像素拆解、源像素调色与少量硬边像素道具叠加；主角色轮廓、光影、帽子、服装、靴子、火炬和地面均保留参考图细节。",
    "background_removed_by": "dark_navy_border_flood_fill",
    "stray_right_edge_tick_removed_in_clean_assets": true,
    "reconstruction_mismatched_pixels": 0,
    "reconstruction_note": "layers/reconstruction 中的拆解层叠加后与 source/reference_transparent_clean_256.png 像素一致。"
  },
  "style_rules": [
    "不要重新手绘粗线条简化版；新增部件必须服从参考图的头身比、2-5px深色外轮廓、红棕/金色高光、硬边阴影。",
    "所有导入与缩放必须关闭双线性/三线性插值，使用 nearest-neighbor。",
    "角色核心 silhouette 固定为参考图，变体优先使用源像素调色，不改变像素块密度。"
  ],
